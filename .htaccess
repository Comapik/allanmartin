Options -Indexes -MultiViews

# Priorité à index.php sur index.html pour l'accueil
DirectoryIndex index.php index.html

# ── O2switch / Apache : variables d'environnement Brevo ─────────────
# Remplacez les valeurs ci-dessous par vos vraies informations Brevo.
# Exemple de clé: xkeysib-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
<IfModule mod_env.c>
  SetEnv BREVO_API_KEY "REMPLACER_PAR_VOTRE_CLE_BREVO"
  SetEnv BREVO_LIST_ID "REMPLACER_PAR_L_ID_NUMERIQUE_DE_LISTE"
</IfModule>

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # ── Retire le .html visible dans l'URL ──────────────
  # 1. Si la requête se termine par .html → redirige sans l'extension (301)
  RewriteCond %{THE_REQUEST} \s/+(.+?)\.html[\s?] [NC]
  RewriteRule ^ /%1 [R=301,L]

  # /index et /index.html → / (racine)
  RewriteCond %{THE_REQUEST} \s/+index(\.html)?[\s?] [NC]
  RewriteRule ^ / [R=301,L]

  # Ancienne URL PHP de bio -> URL propre
  RewriteCond %{THE_REQUEST} \s/+bio\.php[\s?] [NC]
  RewriteRule ^bio\.php$ /bio [R=301,L]

  # Redirige l'ancienne URL /press vers /presse
  RewriteRule ^press$ /presse [R=301,L]

  # Route explicite /bio -> bio.html
  RewriteRule ^bio$ bio.html [L]

  # Cas particulier : /presse → presse.html (conflit avec le dossier press/)
  RewriteRule ^presse$ presse.html [L]

  # 2. Si le fichier .html correspondant existe → le sert en interne (transparent)
  RewriteCond %{REQUEST_FILENAME}      !-d
  RewriteCond %{REQUEST_FILENAME}      !-f
  RewriteCond %{REQUEST_FILENAME}.html -f
  RewriteRule ^(.+)$ $1.html [L]
</IfModule>

# ── Sécurité : bloquer l'accès direct aux fichiers sensibles ──────────
<FilesMatch "^(lang|send).*\.php$">
  # Autoriser send.php (POST du formulaire), bloquer lang/*.php
</FilesMatch>

<FilesMatch "^lang/.+\.php$">
  Order allow,deny
  Deny from all
</FilesMatch>
